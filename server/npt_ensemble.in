units           metal
dimension       3
boundary        p p p
atom_style      atomic

read_data       input.data

# If your data file does not provide masses, uncomment the next line (for a single Al type)
# mass          1 26.9815385

pair_style      eam/alloy
pair_coeff      * * Al99.eam.alloy Al
neighbor        2.0 bin
neigh_modify    delay 0 check yes

thermo          100
thermo_style    custom step temp pe ke etotal press pxx pyy pzz vol lx ly lz

reset_timestep  0
min_style       fire
min_modify      dmax 0.1 line quadratic
minimize        1.0e-12 1.0e-12 10000 100000

variable        Tstart equal 10.0      # K (gentle start)
variable        Tstop  equal 300.0     # K (target temperature)
variable        Pstart equal 0.0       # bar
variable        Pstop  equal 0.0       # bar
variable        Tdamp  equal 0.1       # ps (thermostat damping ~ 100 timesteps)
variable        Pdamp  equal 5.0       # ps (barostat damping ~ 10–50x Tdamp)
variable        dt     equal 0.001     # ps (1 fs)
variable        nsteps equal 200000    # 200 ps total

timestep        ${dt}

# Initialize velocities for NPT
velocity        all create ${Tstart} 4928459 mom yes rot yes dist gaussian

# Isotropic NPT at 0 bar
fix             npt all npt temp ${Tstart} ${Tstop} ${Tdamp} iso ${Pstart} ${Pstop} ${Pdamp}

# Output trajectory (adjust frequency as needed)
dump            trj all custom 1000 npt_al.dump id type x y z vx vy vz
dump_modify     trj sort id

thermo          100
run             ${nsteps}

# Write final relaxed configuration
unfix           npt
unfix           mom
write_data      al_npt_equilibrated.data
write_restart   al_npt_equilibrated.restart

# Notes:
# - If your data file defines multiple atom types that are all Al, the pair_coeff mapping must
#   repeat "Al" for each type, e.g., for 2 types: "pair_coeff * * Al99.eam.alloy Al Al".
# - You can lengthen the NPT run or reduce Tdamp/Pdamp for tighter/stiffer control as needed.