# NPT simulation of Aluminum at 300 K and 1 atm for 100 ps

log log.lammps

units metal
dimension 3
boundary p p p
atom_style atomic

pair_style eam/alloy

read_data /Users/vinaykumar/Desktop/AgenticMD/data/Structures/Al.data

pair_coeff * * /Users/vinaykumar/Desktop/AgenticMD/data/Potentials/Al99.eam.alloy Al

neighbor 2.0 bin
neigh_modify delay 5 every 1 check yes

thermo_style custom step time temp press pe ke etotal vol lx ly lz
thermo 100

timestep 0.001
reset_timestep 0

velocity all create 300.0 4928459 mom yes rot yes dist gaussian

fix 1 all npt temp 300.0 300.0 0.1 iso 1.01325 1.01325 1.0

dump 1 all custom 1000 traj_Al_300K_NPT.lammpstrj id type x y z vx vy vz
dump_modify 1 sort id

run 100000

unfix 1

write_data Al_NPT_300K_final.data
