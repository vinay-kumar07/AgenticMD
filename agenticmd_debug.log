# LAMMPS script: NPT simulation of Aluminum at 300 K and 1 atm for 100 ps

log               log.lammps

units             metal
dimension         3
boundary          p p p
atom_style        atomic

# Read initial configuration
read_data         ./data/aluminum.data

# Interatomic potential (EAM/alloy for Al)
pair_style        eam/alloy
pair_coeff        * * ./potentials/Al99.eam.alloy Al

# Mass for Al (if not defined in data file)
mass              1 26.9815385

# Neighbor settings
neighbor          2.0 bin
neigh_modify      delay 10 check yes

# Time integration parameters
timestep          0.001    # ps (metal units)
velocity          all create 300.0 12345 mom yes rot yes dist gaussian

# Thermo output
thermo            1000
thermo_style      custom step time temp press pe ke etotal vol lx ly lz
thermo_modify     flush yes

# Trajectory dump
dump              d1 all custom 1000 traj_al_npt.lammpstrj id type x y z vx vy vz
dump_modify       d1 sort id

# NPT ensemble at 300 K and 1
